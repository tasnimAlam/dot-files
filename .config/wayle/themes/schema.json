    },
    "blue": { "description": "Blue palette color.", "type": "string" },
    "elevated": {
      "description": "Raised element background.",
      "type": "string"
    },
    "fg": { "description": "Primary text color.", "type": "string" },
    "fg_muted": { "description": "Secondary text color.", "type": "string" },
    "green": { "description": "Green palette color.", "type": "string" },
    "primary": {
      "description": "Accent color for interactive elements.",
      "type": "string"
    },
    "red": { "description": "Red palette color.", "type": "string" },
    "surface": {
      "description": "Card and sidebar background.",
      "type": "string"
    },
    "yellow": { "description": "Yellow palette color.", "type": "string" }
